  "info": {
    "title": "moyura API",
    "description": "moyura 모노레포 백엔드 API (인증 단계)",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "전체 헬스 상태",
            "enum": [
              "ok",
              "degraded"
            ],
            "example": "ok"
          },
          "db": {
            "type": "string",
            "description": "데이터베이스 연결성 결과",
            "enum": [
              "up",
              "down"
            ],
            "example": "up"
          }
        },
        "required": [
          "status",
          "db"
        ]
      },
      "ProfileResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Supabase auth user id(`sub`) — profile의 PK",
            "example": "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
          },
          "createdAt": {
            "type": "string",
            "description": "profile 최초 생성 시각(ISO-8601)",
            "example": "2026-06-02T09:59:34.000Z"
          }
        },
        "required": [
          "id",
          "createdAt"
        ]
      },
      "CreateMoimDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "모임 이름(비어 있을 수 없음)",
            "example": "주말 등산 모임"
          },
          "nickname": {
            "type": "string",
            "description": "생성자의 모임별 표시 이름(host nickname, 비어 있을 수 없음). owner 멤버십에 주입된다.",
            "example": "호스트"
          }
        },
        "required": [
          "name",
          "nickname"
        ]
      },
      "MoimResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "모임 id(uuid)",
            "example": "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
          },
          "name": {
            "type": "string",
            "description": "모임 이름",
            "example": "주말 등산 모임"
          },
          "createdBy": {
            "type": "string",
            "description": "생성자 sub(= profile.id)",
            "example": "00000000-0000-4000-8000-000000000001"
          },
          "createdAt": {
            "type": "string",
            "description": "모임 생성 시각(ISO-8601)",
            "example": "2026-06-13T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "name",
          "createdBy",
          "createdAt"
        ]
      },
      "MemberResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "description": "멤버 sub(= profile.id)",
            "example": "00000000-0000-4000-8000-000000000001"
          },
          "nickname": {
            "type": "string",
            "description": "모임별 표시 이름",
            "example": "호스트"
          },
          "role": {
            "type": "string",
            "description": "멤버 역할(\"owner\" | \"member\")",
            "example": "owner"
          },
          "joinedAt": {
            "type": "string",
            "description": "가입(생성) 시각(ISO-8601)",
            "example": "2026-06-13T00:00:00.000Z"
          }
        },
        "required": [
          "userId",
          "nickname",
          "role",
          "joinedAt"
        ]
      },
      "CreateInviteDto": {
        "type": "object",
        "properties": {
          "expiresAt": {
            "type": "string",
            "description": "만료 시각(ISO-8601). 미지정 시 발급 시점 +7일. 상한 +30일(초과 400).",
            "example": "2026-06-21T00:00:00.000Z"
          },
          "maxUses": {
            "type": "number",
            "description": "선택적 사용 횟수 제한(1 이상의 정수). 미지정 시 무제한.",
            "example": 5
          }
        }
      },
      "InviteResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "초대 id(uuid)",
            "example": "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
          },
          "moimId": {
            "type": "string",
            "description": "대상 모임 id",
            "example": "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
          },
          "token": {
            "type": "string",
            "description": "추측 불가 초대 토큰(base64url, ≥128-bit). 수락 링크에 사용한다.",
            "example": "k3J9_aZ...base64url43chars"
          },
          "expiresAt": {
            "type": "string",
            "description": "만료 시각(ISO-8601)",
            "example": "2026-06-21T00:00:00.000Z"
          },
          "maxUses": {
            "type": "number",
            "description": "사용 횟수 제한(null이면 무제한)",
            "example": 5,
            "nullable": true
          },
          "usedCount": {
            "type": "number",
            "description": "현재 사용 횟수",
            "example": 0
          },
          "revokedAt": {
            "type": "string",
            "description": "폐기 시각(ISO-8601). null이면 미폐기(유효).",
            "example": null,
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "description": "발급 시각(ISO-8601)",
            "example": "2026-06-14T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "moimId",
          "token",
          "expiresAt",
          "maxUses",
          "usedCount",
          "revokedAt",
          "createdAt"
        ]
      },
      "AcceptInviteDto": {
        "type": "object",
        "properties": {
          "nickname": {
            "type": "string",
            "description": "수락자의 모임별 표시 이름(비어 있을 수 없음)",
            "example": "게스트1"
          }
        },
        "required": [
          "nickname"
        ]
      },
      "AcceptInviteResponseDto": {
        "type": "object",
        "properties": {
          "moimId": {
            "type": "string",
            "description": "가입한 모임 id(웹 랜딩이 /moims/:id/chat 리다이렉트에 사용)",
            "example": "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
          }
        },
        "required": [
          "moimId"
        ]
      },
      "SendMessageDto": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "메시지 본문(비어 있을 수 없음, 최대 2000자)",
            "example": "안녕하세요"
          }
        },
        "required": [
          "content"
        ]
      },
      "ChatMessageResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "메시지 id(BigInt PK의 문자열 표현 — 단조 증가, keyset 커서 기준)",
            "example": "42"
          },
          "moimId": {
            "type": "string",
            "description": "메시지가 속한 모임 id",
            "example": "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
          },
          "senderId": {
            "type": "string",
            "description": "발신자 sub(= profile.id). 표시 이름은 멤버 목록에서 클라이언트가 해석한다.",
            "example": "00000000-0000-4000-8000-000000000001"
          },
          "content": {
            "type": "string",
            "description": "메시지 본문",
            "example": "안녕하세요"
          },
          "createdAt": {
            "type": "string",
            "description": "메시지 생성 시각(ISO-8601)",
            "example": "2026-06-14T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "moimId",
          "senderId",
          "content",
          "createdAt"
        ]
      },
      "ChatHistoryResponseDto": {
        "type": "object",
        "properties": {
          "messages": {
            "description": "커서 이전 최신순(내림차순) 메시지 목록",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatMessageResponseDto"
            }
          },
          "nextCursor": {
            "type": "string",
            "description": "다음 페이지 커서(가장 오래된 반환분의 id). 더 없으면 null.",
            "example": "37",
            "nullable": true
          }
        },
        "required": [
          "messages",
          "nextCursor"
        ]
      }
    }
  }
}
