{
  "name": "moyura",
  "version": "1.0.0",
  "private": true,
  "description": "Moyura monorepo (pnpm workspaces + Nx)",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "graph": "nx graph",
    "dev:backend": "pnpm --filter @moyura/backend prisma:generate && pnpm --filter @moyura/backend start:dev",
    "dev:web": "pnpm --filter @moyura/web dev",
    "dev:mobile": "pnpm --filter @moyura/mobile start",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status"
  },
  "devDependencies": {
    "nx": "21.6.7",
    "openapi-typescript": "^7.13.0",
    "supabase": "^2.104.0"
  }
}
