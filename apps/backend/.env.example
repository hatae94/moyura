# moyura backend 환경변수 예시 (SPEC-ENV-SETUP-001)
# 실제 값은 .env (gitignored)에 작성한다. 이 파일만 커밋된다.
# 부팅 시 Zod 스키마(src/config/env.validation.ts)로 검증되며, 필수 변수 누락/오류 시 즉시 종료한다.

# --- 필수 (required) ---

# 런타임 Prisma 클라이언트 연결.
#   prod: Supabase pooled URL (포트 6543, Supavisor transaction-mode, ?pgbouncer=true)
#   local: Supabase CLI 스택 direct URL (포트 54322) — 로컬은 pooler를 노출하지 않을 수 있음
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# 마이그레이션 CLI 전용 direct 연결 (포트 5432 prod / 54322 local).
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# 백엔드 listen 포트 (web dev 서버 :3000 과 충돌 회피). prod는 Render가 PORT를 주입한다.
PORT=3001

# 실행 환경: development | production | test
NODE_ENV=development

# 콤마 구분 CORS 허용 origin (web + mobile). prod에서는 실제 web URL + mobile scheme로 교체.
# Bearer 헤더 인증(OD-3) 사용 → credentials/cookie 불필요. 와일드카드 금지(R-J3).
CORS_ORIGINS="http://192.168.219.102:3000,http://192.168.219.102:8081"

# --- Auth runtime (SPEC-AUTH-001 R-I1): required ---

# Supabase API URL. JWKS URL(`<URL>/auth/v1/.well-known/jwks.json`)과 expected issuer
# (`<URL>/auth/v1`)를 코드에서 파생한다(OD-2/OD-6). local = supabase status Project URL.
SUPABASE_URL="http://127.0.0.1:54321"

# Supabase anon(공개) 키. 프런트가 NEXT_PUBLIC_*/EXPO_PUBLIC_*로 소비. local = supabase status ANON_KEY.
SUPABASE_ANON_KEY="your-local-anon-key"

# --- Auth legacy fallback (optional — 미설정 가능) ---
# 레거시 HS256 공유 시크릿 폴백 전용(R-A4). 실제 HS256 서명 토큰에만 적용된다.
# JWKS-primary(ES256) 운영 시 미설정해도 무방. local = supabase status JWT_SECRET.
# SUPABASE_JWT_SECRET="your-local-jwt-secret"
