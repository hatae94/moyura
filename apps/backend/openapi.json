{
  "openapi": "3.0.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "AppController_getHello",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "App"
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "HealthController_check",
        "parameters": [],
        "responses": {
          "200": {
            "description": "DB 접속 가능 — 정상",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponseDto"
                }
              }
            }
          },
          "503": {
            "description": "DB 접속 불가 — degraded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "health"
        ]
      }
    }
  },
  "info": {
    "title": "moyura API",
    "description": "moyura 모노레포 백엔드 API (인프라 배선 단계)",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "전체 헬스 상태",
            "enum": [
              "ok",
              "degraded"
            ],
            "example": "ok"
          },
          "db": {
            "type": "string",
            "description": "데이터베이스 연결성 결과",
            "enum": [
              "up",
              "down"
            ],
            "example": "up"
          }
        },
        "required": [
          "status",
          "db"
        ]
      }
    }
  }
}
