# Supabase 로컬 스택 소셜 OAuth 시크릿 (SPEC-AUTH-002).
# 이 파일은 placeholder 만 담는다 — 실제 값은 절대 커밋하지 않는다.
#
# 실제 값을 넣을 위치 (Supabase CLI 가 env() 치환에 사용):
#   1순위: 모노레포 루트 `.env`  (루트 .gitignore 가 `.env` 무시 — Supabase docs 기본값)
#   폴백:  `supabase/.env.local` (supabase/.gitignore 가 무시)
#   → `pnpm db:start` 출력으로 실제 치환 여부 검증 (OD-1).
#
# provider 콘솔(Google Cloud)의 authorized redirect URI 에 등록할 값 = GoTrue 콜백
# (웹 앱 콜백 http://127.0.0.1:3000/auth/callback 이 아님):
#   http://127.0.0.1:54321/auth/v1/callback

# --- Google (이번 iteration) ---
# Google Cloud OAuth 2.0 "Web application" 클라이언트의 client id / secret
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# --- Apple (deferred — SPEC-AUTH-002 follow-up) ---
# Apple Developer Program 확보 후 활성화. client_id = Services ID,
# secret = .p8 로 ES256 서명한 client-secret JWT(최대 6개월 만료, 회전 필요).
# SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=
