    "/moims/{id}/polls/{pollId}/close": {
      "post": {
        "operationId": "PollController_close",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pollId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "마감된 poll 결과(closesAt=now, isClosed:true, finalize 필드 포함)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PollResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "유효한 Supabase JWT 부재 — 401"
          },
          "403": {
            "description": "비멤버 또는 생성자가 아닌 멤버 — 403"
          },
          "404": {
            "description": "해당 모임에 속하지 않는(또는 없는) pollId — 404"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": [
          "polls"
        ]
      }
    },
    "/devices": {
      "post": {
        "operationId": "DeviceTokenController_register",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDeviceDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "디바이스 토큰 등록(upsert, 중복 없음)"
          },
          "401": {
            "description": "유효한 Supabase JWT 부재 — 401"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": [
          "devices"
        ]
      }
    },
    "/devices/{token}": {
      "delete": {
        "operationId": "DeviceTokenController_unregister",
        "parameters": [
          {
            "name": "token",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "디바이스 토큰 해제(소유자 한정, orphan token 방지)"
          },
          "401": {
            "description": "유효한 Supabase JWT 부재 — 401"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": [
          "devices"
        ]
      }
    }
  },
  "info": {
    "title": "moyura API",
    "description": "moyura 모노레포 백엔드 API (인증 단계)",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "전체 헬스 상태",
            "enum": [
              "ok",
              "degraded"
            ],
            "example": "ok"
          },
          "db": {
            "type": "string",
            "description": "데이터베이스 연결성 결과",
            "enum": [
              "up",
              "down"
            ],
            "example": "up"
          }
        },
        "required": [
          "status",
          "db"
        ]
      },
      "ProfileResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Supabase auth user id(`sub`) — profile의 PK",
            "example": "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
          },
          "name": {
            "type": "string",
            "description": "사용자 표시 이름(미보유 시 null — 온보딩 가드 대상)",
            "example": "홍길동",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "description": "profile 최초 생성 시각(ISO-8601)",
            "example": "2026-06-02T09:59:34.000Z"
          }
        },
        "required": [
          "id",
          "name",
          "createdAt"
        ]
      },
      "UpdateNameDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "설정할 사용자 표시 이름(trim 후 비어 있을 수 없음)",
            "example": "홍길동"
          }
        },
        "required": [
          "name"
        ]
      },
      "CreateMoimDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "모임 이름(비어 있을 수 없음)",
            "example": "주말 등산 모임"
          },
          "nickname": {
            "type": "string",
            "description": "생성자의 모임별 표시 이름(host nickname, 비어 있을 수 없음). owner 멤버십에 주입된다.",
            "example": "호스트"
          },
          "startsAt": {
            "type": "string",
            "description": "이벤트 일정(ISO-8601, optional). 부재/빈 값이면 일정 미정.",
            "example": "2026-07-01T10:00:00.000Z"
          },
          "location": {
            "type": "string",
            "description": "이벤트 장소(자유 텍스트, optional).",
            "example": "강남역 스타벅스"
          }
        },
        "required": [
          "name",
          "nickname"
        ]
      },
      "MoimResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "모임 id(uuid)",
            "example": "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
          },
          "name": {
            "type": "string",
            "description": "모임 이름",
            "example": "주말 등산 모임"
          },
          "startsAt": {
            "type": "string",
            "description": "이벤트 일정(ISO-8601) 또는 null(일정 미정)",
            "nullable": true,
            "example": "2026-07-01T10:00:00.000Z"
          },
          "location": {
            "type": "string",
            "description": "이벤트 장소(자유 텍스트) 또는 null",
            "nullable": true,
            "example": "강남역 스타벅스"
          },
          "createdBy": {
            "type": "string",
            "description": "생성자 sub(= profile.id)",
            "example": "00000000-0000-4000-8000-000000000001"
          },
          "createdAt": {
            "type": "string",
            "description": "모임 생성 시각(ISO-8601)",
            "example": "2026-06-13T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "name",
          "startsAt",
          "location",
          "createdBy",
          "createdAt"
        ]
      },
      "MemberResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "description": "멤버 sub(= profile.id)",
            "example": "00000000-0000-4000-8000-000000000001"
          },
          "nickname": {
            "type": "string",
            "description": "모임별 표시 이름",
            "example": "호스트"
          },
          "role": {
            "type": "string",
            "description": "멤버 역할(\"owner\" | \"member\")",
            "example": "owner"
          },
          "joinedAt": {
            "type": "string",
            "description": "가입(생성) 시각(ISO-8601)",
            "example": "2026-06-13T00:00:00.000Z"
          }
        },
        "required": [
          "userId",
          "nickname",
          "role",
          "joinedAt"
        ]
      },
      "TransferOwnerDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "description": "소유권을 이양받을 대상 멤버 userId(비어 있을 수 없음)",
            "example": "00000000-0000-4000-8000-000000000002"
          }
        },
        "required": [
          "userId"
        ]
      },
      "CreateInviteDto": {
        "type": "object",
        "properties": {
          "expiresAt": {
            "type": "string",
            "description": "만료 시각(ISO-8601). 미지정 시 발급 시점 +7일. 상한 +30일(초과 400).",
            "example": "2026-06-21T00:00:00.000Z"
          },
          "maxUses": {
            "type": "number",
            "description": "선택적 사용 횟수 제한(1 이상의 정수). 미지정 시 무제한.",
            "example": 5
          }
        }
      },
      "InviteResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "초대 id(uuid)",
            "example": "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
          },
          "moimId": {
            "type": "string",
            "description": "대상 모임 id",
            "example": "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
          },
          "token": {
            "type": "string",
            "description": "추측 불가 초대 토큰(base64url, ≥128-bit). 수락 링크에 사용한다.",
            "example": "k3J9_aZ...base64url43chars"
          },
          "expiresAt": {
            "type": "string",
            "description": "만료 시각(ISO-8601)",
            "example": "2026-06-21T00:00:00.000Z"
          },
          "maxUses": {
            "type": "number",
            "description": "사용 횟수 제한(null이면 무제한)",
            "example": 5,
            "nullable": true
          },
          "usedCount": {
            "type": "number",
            "description": "현재 사용 횟수",
            "example": 0
          },
          "revokedAt": {
            "type": "string",
            "description": "폐기 시각(ISO-8601). null이면 미폐기(유효).",
            "example": null,
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "description": "발급 시각(ISO-8601)",
            "example": "2026-06-14T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "moimId",
          "token",
          "expiresAt",
          "maxUses",
          "usedCount",
          "revokedAt",
          "createdAt"
        ]
      },
      "InviteValidityDto": {
        "type": "object",
        "properties": {
          "moimId": {
            "type": "string",
            "description": "초대가 속한 모임 id",
            "example": "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
          }
        },
        "required": [
          "moimId"
        ]
      },
      "AcceptInviteDto": {
        "type": "object",
        "properties": {
          "nickname": {
            "type": "string",
            "description": "수락자의 모임별 표시 이름(비어 있을 수 없음)",
            "example": "게스트1"
          }
        },
        "required": [
          "nickname"
        ]
      },
      "AcceptInviteResponseDto": {
        "type": "object",
        "properties": {
          "moimId": {
            "type": "string",
            "description": "가입한 모임 id(웹 랜딩이 /moims/:id/chat 리다이렉트에 사용)",
            "example": "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
          }
        },
        "required": [
          "moimId"
        ]
      },
      "SendMessageDto": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "메시지 본문(비어 있을 수 없음, 최대 2000자)",
            "example": "안녕하세요"
          }
        },
        "required": [
          "content"
        ]
      },
      "ChatMessageResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "메시지 id(BigInt PK의 문자열 표현 — 단조 증가, keyset 커서 기준)",
            "example": "42"
          },
          "moimId": {
            "type": "string",
            "description": "메시지가 속한 모임 id",
            "example": "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
          },
          "senderId": {
            "type": "string",
            "description": "발신자 sub(= profile.id). 표시 이름은 멤버 목록에서 클라이언트가 해석한다.",
            "example": "00000000-0000-4000-8000-000000000001"
          },
          "content": {
            "type": "string",
            "description": "메시지 본문",
            "example": "안녕하세요"
          },
          "createdAt": {
            "type": "string",
            "description": "메시지 생성 시각(ISO-8601)",
            "example": "2026-06-14T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "moimId",
          "senderId",
          "content",
          "createdAt"
        ]
      },
      "ChatHistoryResponseDto": {
        "type": "object",
        "properties": {
          "messages": {
            "description": "커서 이전 최신순(내림차순) 메시지 목록",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatMessageResponseDto"
            }
          },
          "nextCursor": {
            "type": "string",
            "description": "다음 페이지 커서(가장 오래된 반환분의 id). 더 없으면 null.",
            "example": "37",
            "nullable": true
          }
        },
        "required": [
          "messages",
          "nextCursor"
        ]
      },
      "CreatePollDto": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string",
            "description": "투표 질문(trim 후 비어 있을 수 없음)",
            "example": "다음 모임 날짜는?"
          },
          "options": {
            "description": "선택지 라벨 배열(trim 후 비지 않은 항목 2개 이상 필요)",
            "example": [
              "토요일",
              "일요일"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "multiSelect": {
            "type": "boolean",
            "description": "여러 개 선택 허용 여부(poll 별 옵트인). true 면 다중 선택(토글), 생략/false 면 단일 선택(교체).",
            "default": false,
            "example": false
          },
          "closesAt": {
            "type": "string",
            "description": "마감 시각(ISO-8601). 생략 시 null(마감 없음 — 영구히 열림). 무효 ISO 는 400 Bad Request.",
            "nullable": true,
            "example": "2026-06-25T12:00:00.000Z"
          },
          "kind": {
            "type": "string",
            "description": "투표 종류. \"date\" 면 options 가 ISO-8601 날짜 문자열 배열(옵션별 optionDate 저장), \"place\" 면 자유 텍스트 장소명(마감 시 승자 label → Moim.location). 생략/\"general\" 이면 일반 자유 텍스트 옵션.",
            "enum": [
              "general",
              "date",
              "place"
            ],
            "default": "general",
            "example": "general"
          }
        },
        "required": [
          "question",
          "options"
        ]
      },
      "PollOptionResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "선택지 id",
            "example": "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
          },
          "label": {
            "type": "string",
            "description": "선택지 라벨",
            "example": "토요일"
          },
          "voteCount": {
            "type": "number",
            "description": "이 선택지의 득표 수(표 0 이면 0)",
            "example": 3
          },
          "optionDate": {
            "type": "string",
            "description": "날짜 투표 옵션의 시각(ISO-8601). 일반 투표 옵션은 null.",
            "nullable": true,
            "example": "2026-06-27T12:00:00.000Z"
          }
        },
        "required": [
          "id",
          "label",
          "voteCount",
          "optionDate"
        ]
      },
      "PollResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "투표 id(uuid)",
            "example": "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
          },
          "question": {
            "type": "string",
            "description": "투표 질문",
            "example": "다음 모임 날짜는?"
          },
          "createdBy": {
            "type": "string",
            "description": "생성자 sub(= profile.id)",
            "example": "00000000-0000-4000-8000-000000000001"
          },
          "createdAt": {
            "type": "string",
            "description": "투표 생성 시각(ISO-8601)",
            "example": "2026-06-20T00:00:00.000Z"
          },
          "multiSelect": {
            "type": "boolean",
            "description": "여러 개 선택 허용 여부(true=다중 선택/토글, false=단일 선택/교체).",
            "example": false
          },
          "kind": {
            "type": "string",
            "description": "투표 종류. \"general\"=일반(자유 텍스트 옵션), \"date\"=날짜 투표(optionDate 있음), \"place\"=장소 투표(마감 시 승자 → location).",
            "enum": [
              "general",
              "date",
              "place"
            ],
            "example": "general"
          },
          "options": {
            "description": "선택지 목록(각 선택지의 득표 수 + optionDate 포함)",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PollOptionResponseDto"
            }
          },
          "myVotes": {
            "description": "호출자 자신이 고른 선택지 id 목록(미투표 시 빈 배열). 단일 선택은 0/1요소, 다중 선택은 0..N요소.",
            "example": [
              "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "closesAt": {
            "type": "string",
            "description": "마감 시각(ISO-8601). null 이면 마감 없음(영구히 열림). 마감 판정은 isClosed 를 권위 있는 출처로 사용한다.",
            "nullable": true,
            "example": "2026-06-25T12:00:00.000Z"
          },
          "isClosed": {
            "type": "boolean",
            "description": "서버 계산 마감 여부(closesAt != null AND closesAt <= 서버 now). 클라이언트 시계 오차 차단용 — 차단/배지 판정에 사용한다.",
            "example": false
          },
          "finalizedStartsAt": {
            "type": "string",
            "description": "자동 확정된 모임 일정(ISO-8601). 날짜 투표 마감 시 단일 최다 득표 옵션의 날짜가 Moim.startsAt 으로 설정된 경우에만 값이 있다. vote/list 응답에선 항상 null.",
            "nullable": true,
            "example": "2026-06-27T12:00:00.000Z"
          },
          "finalizedLocation": {
            "type": "string",
            "description": "자동 확정된 모임 장소. 장소 투표 마감 시 단일 최다 득표 옵션의 장소명이 Moim.location 으로 설정된 경우에만 값이 있다. vote/list 응답·날짜 투표에선 null.",
            "nullable": true,
            "example": "강남역 2번 출구"
          },
          "finalizeSkippedReason": {
            "type": "string",
            "description": "finalize 건너뛴 이유. \"tie\"=동점, \"no_votes\"=표 없음, null=finalize 성공 또는 일반 투표 또는 vote/list 응답.",
            "nullable": true,
            "enum": [
              "tie",
              "no_votes"
            ],
            "example": null
          }
        },
        "required": [
          "id",
          "question",
          "createdBy",
          "createdAt",
          "multiSelect",
          "kind",
          "options",
          "myVotes",
          "closesAt",
          "isClosed",
          "finalizedStartsAt",
          "finalizedLocation",
          "finalizeSkippedReason"
        ]
      },
      "VoteDto": {
        "type": "object",
        "properties": {
          "optionId": {
            "type": "string",
            "description": "선택지 id(해당 poll 에 속해야 함 — 아니면 400)",
            "example": "15ebe4ba-7f12-4e2c-bfa4-a0a9eb5022b8"
          }
        },
        "required": [
          "optionId"
        ]
      },
      "RegisterDeviceDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "FCM/Expo 디바이스 push 토큰(비어 있을 수 없음)",
            "example": "ExponentPushToken[xxxxxxxxxxxxxxxxxxxxxx]"
          },
          "platform": {
            "type": "string",
            "description": "디바이스 플랫폼(비어 있을 수 없음)",
            "example": "ios",
            "enum": [
              "android",
              "ios"
            ]
          }
        },
        "required": [
          "token",
          "platform"
        ]
      }
    }
  }
}
