{
  "$schema": "https://raw.githubusercontent.com/expo/eas-cli/main/packages/eas-json/schema/eas.schema.json",
  "cli": {
    "version": ">= 0.60.0"
  },
  "build": {
    "local": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:3000"
      }
    },
    "local-sim": {
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:3001",
        "EXPO_PUBLIC_WEB_URL": "http://localhost:3000",
        "EXPO_PUBLIC_SUPABASE_URL": "http://127.0.0.1:54321",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0"
      }
    },
    "production": {
      "distribution": "store",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://YOUR_PROD_API_DOMAIN",
        "EXPO_PUBLIC_WEB_URL": "https://YOUR_PROD_WEB_DOMAIN",
        "EXPO_PUBLIC_SUPABASE_URL": "https://YOUR_PROJECT_REF.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "PASTE_PROD_ANON_KEY",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "PASTE_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "PASTE_GOOGLE_IOS_CLIENT_ID.apps.googleusercontent.com"
      }
    }
  }
}
