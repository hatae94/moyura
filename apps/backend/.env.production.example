# moyura backend prod 값 템플릿 — 호스팅(Render 등) 환경변수에 채워 넣는다. 커밋 금지(실값).
#
# 부팅 시 Zod 스키마(src/config/env.validation.ts)로 검증된다 — 필수 변수 누락/형식 오류 시 즉시 종료한다.
# 실제 값은 호스팅 대시보드(Render → Service → Environment)에 입력하고, 채워진 실값 파일은 커밋하지 않는다.

# --- 필수 (required) ---

# [런타임] Prisma 클라이언트가 사용하는 풀드(pooled) 연결. 앱 실행 중 모든 쿼리가 이 URL 로 나간다.
#   위치: Supabase Dashboard → Project Settings → Database → Connection string → Transaction pooler
#   형식: 포트 6543 (Supavisor transaction-mode) + 끝에 ?pgbouncer=true 를 반드시 붙인다.
#   주의(Prisma gotcha): 런타임은 pooler(6543), 마이그레이션은 direct(5432) — 둘을 섞지 않는다.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# [마이그레이션 전용] prisma migrate deploy 가 사용하는 direct 연결. pgbouncer 를 거치지 않는다.
#   위치: Supabase Dashboard → Project Settings → Database → Direct connection
#   형식: 포트 5432 (direct). ?pgbouncer=true 를 붙이지 않는다.
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres"

# 백엔드 listen 포트. prod 호스트(Render 등)가 PORT 를 런타임에 자동 주입하므로
# 보통 직접 설정할 필요가 없다. 호스트가 주입하지 않는 환경에서만 지정한다.
# PORT=3001

# 실행 환경: production 고정.
NODE_ENV=production

# 콤마 구분 CORS 허용 origin. prod web origin 만 넣는다. 와일드카드(*) 금지(R-J3).
#   예: https://moyura.app  (여러 개면 콤마로: https://moyura.app,https://www.moyura.app)
#   네이티브 앱(WebView) 호출은 브라우저 Origin 이 없거나 WebView origin == prod web URL 이므로
#   별도 scheme 를 추가할 필요가 없다(Bearer 헤더 인증, credentials/cookie 불필요).
CORS_ORIGINS="https://YOUR_PROD_WEB_DOMAIN"

# --- Auth runtime (required) ---

# Supabase API URL. 백엔드가 여기서 JWKS(<URL>/auth/v1/.well-known/jwks.json)와
# expected issuer(<URL>/auth/v1)를 파생한다. web/mobile 의 SUPABASE_URL 과 동일한 값.
#   위치: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Supabase anon(공개) 키. 백엔드는 직접 사용하지 않으나 인증 런타임 설정 일관성을 위해 required.
#   위치: Supabase Dashboard → Project Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY="PASTE_PROD_ANON_KEY"

# --- Auth legacy fallback (optional) ---
# 레거시 HS256 공유 시크릿 폴백 전용. JWKS/ES256 가 primary 이므로 보통 미설정한다.
#   위치(필요 시): Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
# SUPABASE_JWT_SECRET="PASTE_PROD_JWT_SECRET"

# --- FCM 발송 (optional) ---
# firebase-admin 서비스 계정 키 JSON(문자열). 미설정 시 푸시 발송이 no-op(앱은 정상 부팅).
# 시크릿이므로 호스팅 env 에만 입력하고 절대 커밋하지 않는다.
# FIREBASE_CREDENTIALS='{"type":"service_account", ... }'
