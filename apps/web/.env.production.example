# moyura web (Next.js) prod 값 템플릿 — 호스팅(Vercel 등) 환경변수에 채워 넣는다. 커밋 금지(실값).
#
# 이 파일은 "어디서 어떤 값을 가져오는지"를 보여주는 placeholder 모음이다.
# 실제 prod 값은 호스팅 대시보드(Vercel → Project → Settings → Environment Variables)에
# 직접 입력하고, 채워진 실값 파일(.env.production / .env.local 등)은 절대 커밋하지 않는다.
#
# 주의: NEXT_PUBLIC_* 는 build 시점에 정적으로 인라인된다(apps/web/lib/env.ts 가드 참고).
#   → 호스팅에서 빌드를 다시 돌려야 값이 반영된다. 값은 모두 "공개(public)" 전제이므로
#     절대 시크릿(서비스 롤 키, OAuth secret, DB 비밀번호)을 여기에 두지 않는다.

# 백엔드 API 베이스 URL (prod 백엔드 도메인).
#   예: https://api.moyura.app  (백엔드 호스팅의 공개 URL)
NEXT_PUBLIC_API_BASE_URL=https://YOUR_PROD_API_DOMAIN

# Supabase Project URL.
#   위치: Supabase Dashboard → Project Settings → API → Project URL
#   형식: https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase anon(공개/publishable) 키.
#   위치: Supabase Dashboard → Project Settings → API → Project API keys → anon public
#   이 키는 공개 전제다(RLS 로 보호). service_role 키는 절대 여기 두지 않는다.
NEXT_PUBLIC_SUPABASE_ANON_KEY=PASTE_PROD_ANON_KEY
