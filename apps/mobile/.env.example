# moyura mobile (Expo) 환경변수 예시 (SPEC-ENV-SETUP-001 R-E2).
# 실제 값은 .env 에 두며 .env 는 커밋하지 않는다(루트 .gitignore 가 처리).
# prod 값은 EAS 프로파일 env(eas.json)에서 주입한다.
#
# 백엔드 API 베이스 URL. EXPO_PUBLIC_ 접두사가 붙은 변수만 앱 번들로 인라인된다.
# 미설정 시 apps/mobile/lib/env.ts 의 가드가 부팅 시 throw 한다(R-E4).
EXPO_PUBLIC_API_BASE_URL=http://192.168.219.102:3001

# 셸이 풀스크린 WebView 로 호스팅할 웹(apps/web) URL (SPEC-MOBILE-001 R-W3).
# 미설정 시 apps/mobile/lib/web-url.ts 의 가드가 부팅 시 throw 한다(R-W2).
# 환경별 호스트 매핑(R-W3):
#   - iOS 시뮬레이터:    http://192.168.219.102:3000
#   - Android 에뮬레이터: http://10.0.2.2:3000  (에뮬레이터에서 192.168.219.102 는 호스트 머신이 아님)
#                         또는 `adb reverse tcp:3000 tcp:3000` 후 http://192.168.219.102:3000 (OD-2)
#   - 실기기:            http://<호스트머신 LAN IP>:3000
#   - prod:              env 로 주입(하드코딩 금지) — 본 SPEC 범위 밖.
# 주의(OD-3): 앱/OAuth 콜백 호스트 일관성을 위해 live source-of-truth = `192.168.219.102`
#   (config.toml site_url / additional_redirect_urls / actions.ts CALLBACK_URL 모두 192.168.219.102).
#   `127.0.0.1` 로 설정하면 쿠키 origin / GoTrue exact-match 불일치로 종단 실패할 수 있다(EC-2).
EXPO_PUBLIC_WEB_URL=http://192.168.219.102:3000

# 공개 Supabase 설정 (SPEC-AUTH-001 R-I4). 모바일 OAuth 진입(시스템 브라우저) 컨텍스트 구성에 사용한다.
# 공개 값만 EXPO_PUBLIC_ 으로 노출한다 — provider 시크릿은 절대 EXPO_PUBLIC_ 에 두지 않는다(시크릿은 config.toml env() 전용).
# 로컬 값은 `pnpm supabase status -o env` 의 API_URL / ANON_KEY 를 사용한다.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# 네이티브 Google Sign-In 공개 client ID (SPEC-MOBILE-004 R-MOB4-001). 둘 다 옵셔널 —
# 미설정이면 Google 로그인 버튼이 비활성(이메일/비번 로그인은 정상)이고 앱은 그대로 부팅한다(lib/env.ts).
# 값은 시크릿이 아니므로 EXPO_PUBLIC_ 으로 노출 가능하다(client secret 은 절대 여기 두지 않는다).
#   주의: EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID 는 Supabase Google provider 의 client_id 와 반드시 동일해야 한다
#         (signInWithIdToken 의 audience == 그 client_id). 불일치 시 토큰 교환이 거부된다.
#   로컬에서는 보통 미설정으로 둔다(아래는 형식 예시일 뿐 — 실제 client ID 로 교체하거나 주석 처리).
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_GOOGLE_IOS_CLIENT_ID.apps.googleusercontent.com
