# moyura web (Next.js) 환경변수 예시 (SPEC-ENV-SETUP-001 R-E1 + SPEC-AUTH-001 R-I4).
# 실제 값은 .env.local 에 두며 .env.local 은 커밋하지 않는다.
#
# 백엔드 API 베이스 URL. NEXT_PUBLIC_ 접두사가 붙은 변수만 브라우저로 인라인된다.
# 미설정 시 apps/web/lib/env.ts 의 가드가 부팅 시 throw 한다(R-E4).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Supabase 공개 설정(@supabase/ssr 클라이언트). 로컬은 `supabase status` 의 API URL/ANON_KEY.
# provider 시크릿은 절대 NEXT_PUBLIC_* 로 노출하지 않는다(R-I4) — config.toml env() 만 사용.
# 미설정 시 apps/web/lib/env.ts 의 가드가 부팅 시 throw 한다(R-I4).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
